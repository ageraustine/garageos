# GarageOS Backend Environment Configuration
# Copy to .env and fill in your values

# ===========================================
# Database (PostgreSQL via Docker)
# ===========================================
DATABASE_URL=postgresql://garageos:garageos@localhost:5432/garageos

# ===========================================
# Security
# ===========================================
SECRET_KEY=change-this-to-a-secure-random-string-in-production
DEBUG=false

# ===========================================
# MinIO / S3 Storage (via Docker)
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=garageos
MINIO_SECRET_KEY=garageos-secret
MINIO_BUCKET=garageos-media
MINIO_SECURE=false

# ===========================================
# CORS - Allowed origins (comma-separated)
# ===========================================
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ===========================================
# Frontend URL (for magic links in SMS)
# ===========================================
FRONTEND_URL=https://your-frontend.vercel.app

# ===========================================
# M-Pesa / Daraja API
# ===========================================
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://api.yourdomain.com/api/v1/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# ===========================================
# Africa's Talking SMS
# ===========================================
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=GarageOS
AT_ENVIRONMENT=sandbox
